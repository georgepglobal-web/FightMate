contains(\"Boxing\").should(\"exist\");\n  });\n});\n\n=== Operation 3 Result (Text) ===\ndescribe(\"Ranking + profile click\", () => {\n  const ts = Date.now();\n\n  function login(name: string) {\n    cy.visit(\"/\");\n    cy.get('input[placeholder*=\"Enter username\"]').clear().type(name);\n    cy.contains(\"button\", \"Get Started\").click();\n  }\n\n  it(\"clicking a user on ranking navigates to their profile\", () => {\n    const name = `profile-${ts}`;\n    login(name);\n    cy.visit(\"/ranking\");\n    cy.wait(3000);\n    cy.get('[class*=\"cursor-pointer\"]').first().click();\n    cy.url().should(\"include\", \"/profile\");\n  });\n\n  it(\"score updates on ranking after logging a session\", () => {\n    const name = `scorer-${ts}`;\n    login(name);\n    cy.visit(\"/log\");\n    cy.get('input[type=\"date\"]').type(\"2025-04-01\");\n    cy.get(\"select\").eq(0).select(\"Boxing\");\n    cy.get(\"select\").eq(1).select(\"Advanced\");\n    cy.contains(\"button\", /log.*session/i).click();\n    cy.visit(\"/ranking\");\n    cy.wait(3000);\n    cy.contains(name).should(\"exist\");\n  });\n});\n\n=== Operation 4 Result (Text) ===\ndescribe(\"Avatar page\", () => {\n  const ts = Date.now();\n\n  it(\"shows all 4 evolution stages\", () => {\n    cy.visit(\"/\");\n    cy.get('input[placeholder*=\"Enter username\"]').clear().type(`avatar-${ts}`);\n    cy.contains(\"button\", \"Get Started\").click();\n    cy.visit(\"/avatar\");\n    cy.contains(\"Novice\").should(\"exist\");\n    cy.contains(\"Intermediate\").should(\"exist\");\n    cy.contains(\"Seasoned\").should(\"exist\");\n    cy.contains(\"Elite\").should(\"exist\");\n  });\n});\n\n=== Operation 5 Result (Text) ===\ndescribe(\"Shoutbox notifications\", () => {\n  function login(username: string) {\n    cy.visit(\"/\");\n    cy.get('input[placeholder*=\"Enter username\"]').clear().type(username);\n    cy.contains(\"button\", \"Get Started\").click();\n    cy.url().should(\"eq\", Cypress.config().baseUrl + \"/\");\